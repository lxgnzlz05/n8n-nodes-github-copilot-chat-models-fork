{
  "name": "n8n-nodes-github-copilot-chat-models",
  "version": "0.1.0",
  "description": "n8n community node for GitHub Copilot chat model integration",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "github",
    "copilot",
    "ai",
    "chat",
    "langchain"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kk17/n8n-nodes-github-copilot-chat-models",
  "author": {
    "name": "kk17"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kk17/n8n-nodes-github-copilot-chat-models.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy-icons",
    "copy-icons": "cp nodes/LmChatGitHubCopilot/github-copilot.svg dist/nodes/LmChatGitHubCopilot/",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist",
    "credentials"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GitHubCopilotApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LmChatGitHubCopilot/LmChatGitHubCopilot.node.js"
    ]
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "n8n-workflow": "^1.120.8",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
